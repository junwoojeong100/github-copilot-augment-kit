<!doctype html>
<html lang="{{LANG}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="color-scheme" content="light">
  <title>{{TITLE}}</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css">
  <style>
{{RUNTIME_CSS}}
  </style>
</head>
<body>
  <div id="app">
    <aside id="sidebar">
      <div class="brand">
        <div class="brand-mark" id="brandMark"></div>
        <div class="brand-copy">
          <div class="brand-name" id="brandName"></div>
          <div class="brand-sub" id="brandSub"></div>
        </div>
      </div>
      <div class="nav-section">Operations Intelligence</div>
      <nav class="nav" id="nav"></nav>
      <div class="learning-card">
        <div class="learning-top"><span id="learningLabel"></span><span class="dot-live"></span></div>
        <div class="learning-value mono" id="learningValue"></div>
        <div class="learning-note" id="learningNote"></div>
        <div class="learning-meter"><span id="learningMeter"></span></div>
      </div>
      <div class="side-user">
        <div class="side-avatar" id="sideAvatar"></div>
        <div class="side-user-copy">
          <div class="side-user-name" id="sideUserName"></div>
          <div class="side-user-role">Executive · Demo workspace</div>
        </div>
      </div>
    </aside>
    <main id="main">
      <header id="topbar">
        <div>
          <div class="top-title" id="topTitle"></div>
          <div class="top-crumb" id="topCrumb"></div>
        </div>
        <div class="top-spacer"></div>
        <span class="demo-badge">● DEMO DATA</span>
        <div class="top-item architecture"><span class="dot-live"></span><span id="infraLabel"></span></div>
        <div class="top-item mono" id="clock">--:--:--</div>
        <button class="notification-button" id="notificationButton" type="button" aria-label="Demo notifications">
          ◇<span class="notification-count" id="notificationCount">4</span>
        </button>
      </header>
      <section id="view" aria-live="polite"></section>
    </main>
  </div>
  <div class="toasts" id="toasts" aria-live="polite"></div>
  <script id="demo-spec" type="application/json">{{DEMO_SPEC_JSON}}</script>
  <script>
{{RUNTIME_JS}}
  </script>
</body>
</html>
